# Cloudflared stack environment variables
#
# Copy to .env and fill in real values.

# Cloudflare Tunnel token used by: cloudflared tunnel run --token
# Keep this secret (do not commit your real token).
TUNNEL_TOKEN=replace-me

# --- Networks ----------------------------------------------------------------
SERVICES_NETWORK_NAME=services

# --- Container image ----------------------------------------------------------
CLOUDFLARED_IMAGE=cloudflare/cloudflared
CLOUDFLARED_TAG=latest

# --- Container lifecycle ------------------------------------------------------
CLOUDFLARED_RESTART=always
CLOUDFLARED_HOSTNAME=cloudflared
CLOUDFLARED_CONTAINER_NAME=cloudflared

# --- Config -------------------------------------------------------------------
CLOUDFLARED_LOGLEVEL=info
# Metrics bind address inside the container (used by healthcheck).
CLOUDFLARED_METRICS_ADDR=127.0.0.1:2000

# --- Healthcheck --------------------------------------------------------------
CLOUDFLARED_HEALTHCHECK_RETRIES=3
CLOUDFLARED_HEALTHCHECK_TIMEOUT=5s
CLOUDFLARED_HEALTHCHECK_INTERVAL=10s
CLOUDFLARED_HEALTHCHECK_START_PERIOD=15s

# --- Logging -----------------------------------------------------------------
CLOUDFLARED_LOG_MAX_FILE=3
CLOUDFLARED_LOG_MAX_SIZE=10m
