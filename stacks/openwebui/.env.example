# OpenWebUI Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Container image
# =============================================================================

OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui
# Recommended for production: pin a specific release tag (example from docs).
# Alternatives include: main, main-slim, cuda (see OpenWebUI docs).
OPENWEBUI_TAG=v0.6.42

# =============================================================================
# Container lifecycle / identity
# =============================================================================

OPENWEBUI_RESTART=always
OPENWEBUI_HOSTNAME=openwebui
OPENWEBUI_CONTAINER_NAME=openwebui

# =============================================================================
# App configuration
# =============================================================================

# Container timezone
OPENWEBUI_TIMEZONE=Etc/UTC

# OpenWebUI listens on port 8080 inside the container.
OPENWEBUI_PORT=8080

# IMPORTANT: Single-user mode disables login and is irreversible once used.
# Keep this enabled for multi-user deployments.
OPENWEBUI_AUTH=true

# Recommended: set a strong secret key.
# Generate one: openssl rand -base64 48
OPENWEBUI_SECRET_KEY=

# Connect to an Ollama instance:
# - host: http://host.docker.internal:11434
# - another container on `services`: http://ollama:11434
OPENWEBUI_OLLAMA_BASE_URL=http://host.docker.internal:11434

# Optional OpenAI-compatible endpoint
OPENWEBUI_OPENAI_API_BASE_URL=
OPENWEBUI_OPENAI_API_KEY=

# =============================================================================
# Privacy / telemetry
# =============================================================================

OPENWEBUI_SCARF_NO_ANALYTICS=true
OPENWEBUI_DO_NOT_TRACK=true
OPENWEBUI_ANONYMIZED_TELEMETRY=false

# =============================================================================
# Reverse proxy / CORS (tighten when possible)
# =============================================================================

OPENWEBUI_CORS_ALLOW_ORIGIN=*
OPENWEBUI_FORWARDED_ALLOW_IPS=*

# =============================================================================
# Healthcheck / logging
# =============================================================================

OPENWEBUI_HEALTHCHECK_RETRIES=5
OPENWEBUI_HEALTHCHECK_TIMEOUT=5s
OPENWEBUI_HEALTHCHECK_INTERVAL=10s
OPENWEBUI_HEALTHCHECK_START_PERIOD=15s

OPENWEBUI_LOG_MAX_FILE=3
OPENWEBUI_LOG_MAX_SIZE=10m

# =============================================================================
# Persistence
# =============================================================================

OPENWEBUI_DATA_VOLUME_NAME=openwebui-data

# =============================================================================
# Networks
# =============================================================================

# Shared upstream network (external; must be created once)
SERVICES_NETWORK_NAME=services

# Internal network for this stack (created by this compose)
OPENWEBUI_NETWORK_NAME=openwebui
OPENWEBUI_NETWORK_SUBNET=172.100.0.0/24
OPENWEBUI_NETWORK_GATEWAY=172.100.0.1
