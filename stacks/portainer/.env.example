# Portainer Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yaml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Docker Compose Configuration
# =============================================================================

# Container images
PORTAINER_IMAGE=portainer/portainer-ee
PORTAINER_TAG=lts
PORTAINER_SOCKET_PROXY_IMAGE=ghcr.io/tecnativa/docker-socket-proxy
PORTAINER_SOCKET_PROXY_TAG=latest

# Container lifecycle
PORTAINER_RESTART=always
PORTAINER_SOCKET_PROXY_RESTART=always

# Container hostnames
PORTAINER_HOSTNAME=portainer
PORTAINER_SOCKET_PROXY_HOSTNAME=portainer-socket-proxy

# Container names
PORTAINER_CONTAINER_NAME=portainer
PORTAINER_SOCKET_PROXY_CONTAINER_NAME=portainer-socket-proxy

# Socket proxy service name (used in Portainer command to connect to proxy)
PORTAINER_SOCKET_PROXY_SERVICE_NAME=portainer-socket-proxy

# =============================================================================
# Port Configuration
# =============================================================================

# Host port -> container port mapping for Portainer HTTPS
PORTAINER_HOST_HTTPS_PORT=9443
PORTAINER_CONTAINER_HTTPS_PORT=9443

# Socket proxy listens on this port inside the stack network
PORTAINER_SOCKET_PROXY_PORT=2375

# =============================================================================
# Volume Mounts
# =============================================================================

# Docker socket mount for the socket proxy
# Consider adding :ro if your usage allows read-only access
PORTAINER_DOCKER_SOCK_MOUNT=/var/run/docker.sock:/var/run/docker.sock

# =============================================================================
# Portainer Configuration
# =============================================================================

# Timezone inside the container
PORTAINER_TIMEZONE=Etc/UTC

# Trusted origins for Portainer when behind a reverse proxy
# Comma-separated list; no spaces. Examples: example.com,portainer.example.com:9443
PORTAINER_ORIGINS=localhost

# =============================================================================
# Healthcheck Configuration
# =============================================================================

# Socket proxy healthcheck settings
PORTAINER_SOCKET_PROXY_HEALTHCHECK_RETRIES=5
PORTAINER_SOCKET_PROXY_HEALTHCHECK_TIMEOUT=5s
PORTAINER_SOCKET_PROXY_HEALTHCHECK_INTERVAL=10s
PORTAINER_SOCKET_PROXY_HEALTHCHECK_START_PERIOD=15s

# Portainer healthcheck settings
PORTAINER_HEALTHCHECK_RETRIES=5
PORTAINER_HEALTHCHECK_TIMEOUT=5s
PORTAINER_HEALTHCHECK_INTERVAL=10s
PORTAINER_HEALTHCHECK_START_PERIOD=15s

# =============================================================================
# Logging Configuration
# =============================================================================

# Socket proxy logging
PORTAINER_SOCKET_PROXY_LOG_MAX_FILE=3
PORTAINER_SOCKET_PROXY_LOG_MAX_SIZE=10m

# Portainer logging
PORTAINER_LOG_MAX_FILE=3
PORTAINER_LOG_MAX_SIZE=10m

# =============================================================================
# Volume Names
# =============================================================================

# Persistent data volume for Portainer
PORTAINER_DATA_VOLUME_NAME=portainer

# =============================================================================
# Network Configuration
# =============================================================================

# Shared upstream network (external; must be created once)
SERVICES_NETWORK_NAME=services

# Internal network for this stack (created by this compose)
PORTAINER_NETWORK_NAME=portainer
PORTAINER_NETWORK_SUBNET=172.1.0.0/24
PORTAINER_NETWORK_GATEWAY=172.1.0.1
