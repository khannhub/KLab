# Authentik Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yaml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Docker Compose Configuration
# =============================================================================

# Container images and tags
AUTHENTIK_IMAGE=authentik/server
AUTHENTIK_TAG=2025.10
AUTHENTIK_REDIS_IMAGE=redis
AUTHENTIK_REDIS_TAG=alpine
AUTHENTIK_POSTGRES_IMAGE=postgres
AUTHENTIK_POSTGRES_TAG=alpine
AUTHENTIK_SOCKET_PROXY_IMAGE=ghcr.io/tecnativa/docker-socket-proxy
AUTHENTIK_SOCKET_PROXY_TAG=latest

# Container lifecycle
AUTHENTIK_SERVER_RESTART=always
AUTHENTIK_WORKER_RESTART=always
AUTHENTIK_REDIS_RESTART=always
AUTHENTIK_POSTGRES_RESTART=always
AUTHENTIK_SOCKET_PROXY_RESTART=always

# Container hostnames
AUTHENTIK_SERVER_HOSTNAME=authentik-server
AUTHENTIK_WORKER_HOSTNAME=authentik-worker
AUTHENTIK_REDIS_HOSTNAME=authentik-redis
AUTHENTIK_POSTGRES_HOSTNAME=authentik-postgresql
AUTHENTIK_SOCKET_PROXY_HOSTNAME=authentik-socket-proxy

# Container names
AUTHENTIK_SERVER_CONTAINER_NAME=authentik-server
AUTHENTIK_WORKER_CONTAINER_NAME=authentik-worker
AUTHENTIK_REDIS_CONTAINER_NAME=authentik-redis
AUTHENTIK_POSTGRES_CONTAINER_NAME=authentik-postgresql
AUTHENTIK_SOCKET_PROXY_CONTAINER_NAME=authentik-socket-proxy

# =============================================================================
# Port Configuration
# =============================================================================

# Socket proxy listens on this port inside the stack network
AUTHENTIK_SOCKET_PROXY_PORT=2375

# =============================================================================
# Volume Mounts
# =============================================================================

# Docker socket mount for the socket proxy
# Consider adding :ro if your usage allows read-only access
AUTHENTIK_DOCKER_SOCK_MOUNT=/var/run/docker.sock:/var/run/docker.sock

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis snapshot persistence settings
AUTHENTIK_REDIS_SAVE_SECONDS=60
AUTHENTIK_REDIS_SAVE_CHANGES=1
AUTHENTIK_REDIS_LOGLEVEL=warning

# =============================================================================
# PostgreSQL Configuration
# =============================================================================

# Database name/user can usually stay as defaults; password must be set in .env.
POSTGRES_DB=authentik
POSTGRES_USER=authentik
# Required: set a strong password for the database user.
POSTGRES_PASSWORD=replace-me

# =============================================================================
# Authentik Application Configuration
# =============================================================================

# Required: used to encrypt sensitive data at rest.
# Generate one (examples):
# - openssl rand -base64 48
# - python -c "import secrets; print(secrets.token_urlsafe(64))"
AUTHENTIK_SECRET_KEY=replace-me

# Log level for authentik (server + worker)
AUTHENTIK_LOG_LEVEL=info

# Enable/disable upstream error reporting
AUTHENTIK_ERROR_REPORTING__ENABLED=false

# =============================================================================
# Email Configuration (optional)
# =============================================================================

# If you want password reset emails, invitations, etc., configure SMTP.
AUTHENTIK_EMAIL__HOST=
AUTHENTIK_EMAIL__PORT=587
AUTHENTIK_EMAIL__FROM=authentik@localhost
AUTHENTIK_EMAIL__USE_TLS=true
AUTHENTIK_EMAIL__USE_SSL=false
AUTHENTIK_EMAIL__USERNAME=
AUTHENTIK_EMAIL__PASSWORD=

# =============================================================================
# Healthcheck Configuration
# =============================================================================

# Redis healthcheck settings
AUTHENTIK_REDIS_HEALTHCHECK_RETRIES=5
AUTHENTIK_REDIS_HEALTHCHECK_TIMEOUT=5s
AUTHENTIK_REDIS_HEALTHCHECK_INTERVAL=10s
AUTHENTIK_REDIS_HEALTHCHECK_START_PERIOD=15s

# PostgreSQL healthcheck settings
AUTHENTIK_POSTGRES_HEALTHCHECK_RETRIES=5
AUTHENTIK_POSTGRES_HEALTHCHECK_TIMEOUT=5s
AUTHENTIK_POSTGRES_HEALTHCHECK_INTERVAL=10s
AUTHENTIK_POSTGRES_HEALTHCHECK_START_PERIOD=15s

# Socket proxy healthcheck settings
AUTHENTIK_SOCKET_PROXY_HEALTHCHECK_RETRIES=5
AUTHENTIK_SOCKET_PROXY_HEALTHCHECK_TIMEOUT=5s
AUTHENTIK_SOCKET_PROXY_HEALTHCHECK_INTERVAL=10s
AUTHENTIK_SOCKET_PROXY_HEALTHCHECK_START_PERIOD=15s

# Authentik server healthcheck settings
AUTHENTIK_SERVER_HEALTHCHECK_RETRIES=5
AUTHENTIK_SERVER_HEALTHCHECK_TIMEOUT=5s
AUTHENTIK_SERVER_HEALTHCHECK_INTERVAL=10s
AUTHENTIK_SERVER_HEALTHCHECK_START_PERIOD=15s

# Authentik worker healthcheck settings
AUTHENTIK_WORKER_HEALTHCHECK_RETRIES=5
AUTHENTIK_WORKER_HEALTHCHECK_TIMEOUT=5s
AUTHENTIK_WORKER_HEALTHCHECK_INTERVAL=10s
AUTHENTIK_WORKER_HEALTHCHECK_START_PERIOD=15s

# =============================================================================
# Logging Configuration
# =============================================================================

# Redis logging
AUTHENTIK_REDIS_LOG_MAX_FILE=3
AUTHENTIK_REDIS_LOG_MAX_SIZE=10m

# PostgreSQL logging
AUTHENTIK_POSTGRES_LOG_MAX_FILE=3
AUTHENTIK_POSTGRES_LOG_MAX_SIZE=10m

# Socket proxy logging
AUTHENTIK_SOCKET_PROXY_LOG_MAX_FILE=3
AUTHENTIK_SOCKET_PROXY_LOG_MAX_SIZE=10m

# Authentik server logging
AUTHENTIK_SERVER_LOG_MAX_FILE=3
AUTHENTIK_SERVER_LOG_MAX_SIZE=10m

# Authentik worker logging
AUTHENTIK_WORKER_LOG_MAX_FILE=3
AUTHENTIK_WORKER_LOG_MAX_SIZE=10m

# =============================================================================
# Volume Names
# =============================================================================

# Redis persistence
AUTHENTIK_REDIS_VOLUME_NAME=authentik-redis

# PostgreSQL database persistence
AUTHENTIK_POSTGRES_VOLUME_NAME=authentik-postgresql

# Uploaded media and generated assets
AUTHENTIK_MEDIA_VOLUME_NAME=authentik-media

# Custom templates
AUTHENTIK_TEMPLATES_VOLUME_NAME=authentik-templates

# Blueprints for configuration-as-code
AUTHENTIK_BLUEPRINTS_VOLUME_NAME=authentik-blueprints

# =============================================================================
# Network Configuration
# =============================================================================

# Shared upstream network (external; must be created once)
SERVICES_NETWORK_NAME=services

# Internal network for this stack (created by this compose)
AUTHENTIK_NETWORK_NAME=authentik
AUTHENTIK_NETWORK_SUBNET=172.3.0.0/24
AUTHENTIK_NETWORK_GATEWAY=172.3.0.1
