# WhoDB Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Images / tags
# =============================================================================

WHODB_IMAGE=clidey/whodb
WHODB_TAG=latest

# =============================================================================
# Timezone / general config
# =============================================================================

WHODB_TIMEZONE=Etc/UTC

# =============================================================================
# Optional AI integrations
# =============================================================================

WHODB_OLLAMA_HOST=
WHODB_OLLAMA_PORT=11434

WHODB_OPENAI_API_KEY=
WHODB_OPENAI_ENDPOINT=

WHODB_ANTHROPIC_API_KEY=
WHODB_ANTHROPIC_ENDPOINT=

# =============================================================================
# Container lifecycle / identity
# =============================================================================

WHODB_RESTART=always
WHODB_HOSTNAME=whodb
WHODB_CONTAINER_NAME=whodb

# =============================================================================
# Logging
# =============================================================================

WHODB_LOG_MAX_FILE=3
WHODB_LOG_MAX_SIZE=10m

# =============================================================================
# Networks
# =============================================================================

# Shared upstream network (external; must be created once)
SERVICES_NETWORK_NAME=services
