# Example Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Docker Compose Configuration
# =============================================================================

# Container image and tag
EXAMPLE_IMAGE=traefik/whoami
EXAMPLE_TAG=latest

# Container lifecycle
EXAMPLE_RESTART=unless-stopped

# Container hostname
EXAMPLE_HOSTNAME=example

# Container name
EXAMPLE_CONTAINER_NAME=example

# =============================================================================
# Port Configuration
# =============================================================================

# Host port -> container port mapping
EXAMPLE_PORT=8080

# =============================================================================
# Application Configuration
# =============================================================================

# Container timezone
TZ=UTC

# =============================================================================
# Network Configuration
# =============================================================================

# Shared upstream network (external; must be created once)
SERVICES_NETWORK_NAME=services
