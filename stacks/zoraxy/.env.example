# Zoraxy Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yaml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Docker Compose Configuration
# =============================================================================

# Container images and tags
ZORAXY_IMAGE=zoraxydocker/zoraxy
ZORAXY_TAG=latest
ZORAXY_SOCKET_PROXY_IMAGE=ghcr.io/tecnativa/docker-socket-proxy
ZORAXY_SOCKET_PROXY_TAG=latest

# Container lifecycle
ZORAXY_RESTART=always
ZORAXY_SOCKET_PROXY_RESTART=always

# Container hostnames
ZORAXY_HOSTNAME=zoraxy
ZORAXY_SOCKET_PROXY_HOSTNAME=zoraxy-socket-proxy

# Container names
ZORAXY_CONTAINER_NAME=zoraxy
ZORAXY_SOCKET_PROXY_CONTAINER_NAME=zoraxy-socket-proxy

# Socket proxy service name (used in Zoraxy DOCKER_HOST environment variable)
ZORAXY_SOCKET_PROXY_SERVICE_NAME=zoraxy-socket-proxy

# =============================================================================
# Port Configuration
# =============================================================================

# Host port -> container port mappings
ZORAXY_HOST_HTTP_PORT=80
ZORAXY_HOST_HTTPS_PORT=443
ZORAXY_HOST_HTTPS_UDP_PORT=443
ZORAXY_HOST_UI_PORT=8000

# Container UI port used by healthcheck
ZORAXY_CONTAINER_UI_PORT=8000

# Socket proxy listens on this port inside the stack network
ZORAXY_SOCKET_PROXY_PORT=2375

# =============================================================================
# Volume Mounts
# =============================================================================

# Docker socket mount for the socket proxy (read-only)
ZORAXY_DOCKER_SOCK_MOUNT=/var/run/docker.sock:/var/run/docker.sock:ro

# Optional localtime mount
ZORAXY_LOCALTIME_MOUNT=/etc/localtime:/etc/localtime:ro

# =============================================================================
# Zoraxy Configuration
# =============================================================================

# Timezone inside the container
ZORAXY_TIMEZONE=Etc/UTC

# Toggle optional features (see Zoraxy docs for details)
ZORAXY_ZEROTIER=true
ZORAXY_FASTGEOIP=false

# =============================================================================
# Healthcheck Configuration
# =============================================================================

# Socket proxy healthcheck settings
ZORAXY_SOCKET_PROXY_HEALTHCHECK_RETRIES=5
ZORAXY_SOCKET_PROXY_HEALTHCHECK_TIMEOUT=5s
ZORAXY_SOCKET_PROXY_HEALTHCHECK_INTERVAL=10s
ZORAXY_SOCKET_PROXY_HEALTHCHECK_START_PERIOD=15s

# Zoraxy healthcheck settings
ZORAXY_HEALTHCHECK_RETRIES=5
ZORAXY_HEALTHCHECK_TIMEOUT=5s
ZORAXY_HEALTHCHECK_INTERVAL=10s
ZORAXY_HEALTHCHECK_START_PERIOD=15s

# =============================================================================
# Logging Configuration
# =============================================================================

# Socket proxy logging
ZORAXY_SOCKET_PROXY_LOG_MAX_FILE=3
ZORAXY_SOCKET_PROXY_LOG_MAX_SIZE=10m

# Zoraxy logging
ZORAXY_LOG_MAX_FILE=3
ZORAXY_LOG_MAX_SIZE=10m

# =============================================================================
# Volume Names
# =============================================================================

# Persistent config volume
ZORAXY_CONFIG_VOLUME_NAME=zoraxy-config

# Persistent plugins volume
ZORAXY_PLUGINS_VOLUME_NAME=zoraxy-plugins

# =============================================================================
# Network Configuration
# =============================================================================

# External shared networks (must match other stacks)
SERVICES_NETWORK_NAME=services

# Internal network for this stack (created by this compose)
ZORAXY_NETWORK_NAME=zoraxy
ZORAXY_NETWORK_SUBNET=172.2.0.0/24
ZORAXY_NETWORK_GATEWAY=172.2.0.1
