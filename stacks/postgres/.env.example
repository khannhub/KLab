# Postgres Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Images / tags
# =============================================================================

POSTGRES_IMAGE=postgres
POSTGRES_TAG=16

# =============================================================================
# Core database configuration (REQUIRED)
# =============================================================================

POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me

# =============================================================================
# Timezone / general config
# =============================================================================

POSTGRES_TIMEZONE=Etc/UTC

# =============================================================================
# Container lifecycle / identity
# =============================================================================

POSTGRES_RESTART=always
POSTGRES_HOSTNAME=postgres
POSTGRES_CONTAINER_NAME=postgres

# =============================================================================
# Healthchecks / logging
# =============================================================================

POSTGRES_HEALTHCHECK_RETRIES=5
POSTGRES_HEALTHCHECK_TIMEOUT=5s
POSTGRES_HEALTHCHECK_INTERVAL=10s
POSTGRES_HEALTHCHECK_START_PERIOD=15s

POSTGRES_LOG_MAX_FILE=3
POSTGRES_LOG_MAX_SIZE=10m

# =============================================================================
# Persistence
# =============================================================================

POSTGRES_DATA_VOLUME_NAME=postgres-data

# =============================================================================
# Networks
# =============================================================================

# Shared upstream network (external; must be created once)
SERVICES_NETWORK_NAME=services
