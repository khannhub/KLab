# LibreChat Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Images / tags
# =============================================================================

# LibreChat (stable release image)
LIBRECHAT_IMAGE=ghcr.io/danny-avila/librechat
LIBRECHAT_TAG=latest

# MongoDB
LIBRECHAT_MONGO_IMAGE=mongo
LIBRECHAT_MONGO_TAG=8.0.17

# Meilisearch
LIBRECHAT_MEILI_IMAGE=getmeili/meilisearch
LIBRECHAT_MEILI_TAG=v1.12.3

# Vector DB for RAG API (pgvector)
LIBRECHAT_VECTORDB_IMAGE=pgvector/pgvector
LIBRECHAT_VECTORDB_TAG=0.8.0-pg15-trixie

# RAG API (lite) image
LIBRECHAT_RAG_API_IMAGE=ghcr.io/danny-avila/librechat-rag-api-dev-lite
LIBRECHAT_RAG_API_TAG=latest

# =============================================================================
# Service ports / general config
# =============================================================================

LIBRECHAT_PORT=3080
LIBRECHAT_NODE_ENV=production
LIBRECHAT_TIMEZONE=Etc/UTC

# RAG API port (internal)
LIBRECHAT_RAG_PORT=8000

# =============================================================================
# REQUIRED secrets (production-grade)
# =============================================================================
#
# Upstream guidance (helm chart):
# - Generate with openssl rand -hex 32 (CREDS_KEY, JWT_SECRET, JWT_REFRESH_SECRET, MEILI_MASTER_KEY)
# - Generate with openssl rand -hex 16 (CREDS_IV)
# https://raw.githubusercontent.com/danny-avila/LibreChat/main/helm/librechat/readme.md
#
# Replace these placeholders before deploying publicly.

CREDS_KEY=replace-me
CREDS_IV=replace-me
JWT_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
MEILI_MASTER_KEY=replace-me

# =============================================================================
# MongoDB configuration
# =============================================================================

# Root/admin credentials (required when MongoDB auth is enabled)
LIBRECHAT_MONGO_ROOT_USERNAME=root
LIBRECHAT_MONGO_ROOT_PASSWORD=replace-me

# LibreChat DB + app credentials (the init script creates this user on first boot)
LIBRECHAT_MONGO_DB=LibreChat
LIBRECHAT_MONGO_USER=librechat
LIBRECHAT_MONGO_PASSWORD=replace-me

# =============================================================================
# Vector DB (Postgres) configuration
# =============================================================================

LIBRECHAT_VECTORDB_POSTGRES_DB=librechat
LIBRECHAT_VECTORDB_POSTGRES_USER=librechat
LIBRECHAT_VECTORDB_POSTGRES_PASSWORD=replace-me

# =============================================================================
# Reverse proxy settings (recommended when behind a gateway)
# =============================================================================

# Set these to your external URL(s) when using OAuth or a reverse proxy.
DOMAIN_CLIENT=http://localhost:3080
DOMAIN_SERVER=http://localhost:3080

# See LibreChat docs; 1 is a common value behind a reverse proxy.
TRUST_PROXY=1

# Reduce search engine indexing
NO_INDEX=true

# =============================================================================
# Container lifecycle / identity
# =============================================================================

LIBRECHAT_RESTART=always
LIBRECHAT_HOSTNAME=librechat
LIBRECHAT_CONTAINER_NAME=librechat

LIBRECHAT_MONGO_RESTART=always
LIBRECHAT_MONGO_HOSTNAME=librechat-mongodb
LIBRECHAT_MONGO_CONTAINER_NAME=librechat-mongodb

LIBRECHAT_MEILI_RESTART=always
LIBRECHAT_MEILI_HOSTNAME=librechat-meilisearch
LIBRECHAT_MEILI_CONTAINER_NAME=librechat-meilisearch

LIBRECHAT_VECTORDB_RESTART=always
LIBRECHAT_VECTORDB_HOSTNAME=librechat-vectordb
LIBRECHAT_VECTORDB_CONTAINER_NAME=librechat-vectordb

LIBRECHAT_RAG_API_RESTART=always
LIBRECHAT_RAG_API_HOSTNAME=librechat-rag-api
LIBRECHAT_RAG_API_CONTAINER_NAME=librechat-rag-api

# =============================================================================
# Service discovery (normally leave defaults)
# =============================================================================

LIBRECHAT_MONGO_SERVICE_NAME=librechat-mongodb
LIBRECHAT_MONGO_PORT=27017

LIBRECHAT_MEILI_SERVICE_NAME=librechat-meilisearch
LIBRECHAT_MEILI_PORT=7700
LIBRECHAT_MEILI_NO_ANALYTICS=true

LIBRECHAT_RAG_API_SERVICE_NAME=librechat-rag-api
LIBRECHAT_RAG_DB_HOST=librechat-vectordb

# =============================================================================
# Healthchecks / logging
# =============================================================================

LIBRECHAT_HEALTHCHECK_RETRIES=5
LIBRECHAT_HEALTHCHECK_TIMEOUT=5s
LIBRECHAT_HEALTHCHECK_INTERVAL=10s
LIBRECHAT_HEALTHCHECK_START_PERIOD=15s

LIBRECHAT_MONGO_HEALTHCHECK_RETRIES=5
LIBRECHAT_MONGO_HEALTHCHECK_TIMEOUT=5s
LIBRECHAT_MONGO_HEALTHCHECK_INTERVAL=10s
LIBRECHAT_MONGO_HEALTHCHECK_START_PERIOD=15s

LIBRECHAT_VECTORDB_HEALTHCHECK_RETRIES=5
LIBRECHAT_VECTORDB_HEALTHCHECK_TIMEOUT=5s
LIBRECHAT_VECTORDB_HEALTHCHECK_INTERVAL=10s
LIBRECHAT_VECTORDB_HEALTHCHECK_START_PERIOD=15s

LIBRECHAT_LOG_MAX_FILE=3
LIBRECHAT_LOG_MAX_SIZE=10m

LIBRECHAT_MONGO_LOG_MAX_FILE=3
LIBRECHAT_MONGO_LOG_MAX_SIZE=10m

LIBRECHAT_MEILI_LOG_MAX_FILE=3
LIBRECHAT_MEILI_LOG_MAX_SIZE=10m

LIBRECHAT_VECTORDB_LOG_MAX_FILE=3
LIBRECHAT_VECTORDB_LOG_MAX_SIZE=10m

LIBRECHAT_RAG_API_LOG_MAX_FILE=3
LIBRECHAT_RAG_API_LOG_MAX_SIZE=10m

# =============================================================================
# Persistence
# =============================================================================

LIBRECHAT_MONGO_VOLUME_NAME=librechat-mongodb-data
LIBRECHAT_MEILI_VOLUME_NAME=librechat-meilisearch-data
LIBRECHAT_VECTORDB_VOLUME_NAME=librechat-vectordb-data

LIBRECHAT_IMAGES_VOLUME_NAME=librechat-images
LIBRECHAT_UPLOADS_VOLUME_NAME=librechat-uploads
LIBRECHAT_LOGS_VOLUME_NAME=librechat-logs

# =============================================================================
# Networks
# =============================================================================

# Shared upstream network (external; must be created once)
SERVICES_NETWORK_NAME=services

# Internal network for this stack (created by this compose)
LIBRECHAT_NETWORK_NAME=librechat
LIBRECHAT_NETWORK_SUBNET=172.101.0.0/24
LIBRECHAT_NETWORK_GATEWAY=172.101.0.1
