# SillyTavern Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Docker Compose Configuration
# =============================================================================

# Container image and tag
SILLYTAVERN_IMAGE=ghcr.io/sillytavern/sillytavern
SILLYTAVERN_TAG=latest

# Container lifecycle
SILLYTAVERN_RESTART=always
SILLYTAVERN_HOSTNAME=sillytavern
SILLYTAVERN_CONTAINER_NAME=sillytavern

# Port configuration (exposed only to Docker networks, not host)
SILLYTAVERN_PORT=8000

# Timezone and localtime
SILLYTAVERN_TIMEZONE=Etc/UTC
SILLYTAVERN_LOCALTIME_MOUNT=/etc/localtime:/etc/localtime:ro

# =============================================================================
# SillyTavern: Data Configuration
# =============================================================================

SILLYTAVERN_DATAROOT=./data
SILLYTAVERN_SKIPCONTENTCHECK=false
SILLYTAVERN_ENABLEDOWNLOADABLETOKENIZERS=true

# =============================================================================
# SillyTavern: Logging Configuration
# =============================================================================

SILLYTAVERN_LOGGING_MINLOGLEVEL=1
SILLYTAVERN_LOGGING_ENABLEACCESSLOG=true

# =============================================================================
# SillyTavern: Network Configuration
# =============================================================================

SILLYTAVERN_LISTEN=true
SILLYTAVERN_DNSPREFERIPV6=false
SILLYTAVERN_PROTOCOL_IPV4=true
SILLYTAVERN_PROTOCOL_IPV6=false
SILLYTAVERN_LISTENADDRESS_IPV4=0.0.0.0
SILLYTAVERN_LISTENADDRESS_IPV6=[::]

# =============================================================================
# SillyTavern: SSL Configuration
# =============================================================================

SILLYTAVERN_SSL_ENABLED=false
SILLYTAVERN_SSL_KEYPATH=./certs/privkey.pem
SILLYTAVERN_SSL_CERTPATH=./certs/cert.pem
SILLYTAVERN_SSL_KEYPASSPHRASE=

# =============================================================================
# SillyTavern: Security Configuration
# =============================================================================

SILLYTAVERN_DISABLECSRFPROTECTION=false
SILLYTAVERN_SECURITYOVERRIDE=false
SILLYTAVERN_ALLOWKEYSEXPOSURE=false

# =============================================================================
# SillyTavern: IP Whitelisting
# =============================================================================

# JSON array format: ["::1", "127.0.0.1", "172.10.0.0/24"]
SILLYTAVERN_WHITELIST=["::1", "127.0.0.1", "172.10.0.0/24"]
SILLYTAVERN_WHITELISTMODE=true
SILLYTAVERN_WHITELISTDOCKERHOSTS=true
SILLYTAVERN_ENABLEFORWARDEDWHITELIST=false

# =============================================================================
# SillyTavern: Host Whitelisting
# =============================================================================

SILLYTAVERN_HOSTWHITELIST_SCAN=true
# JSON array format: []
SILLYTAVERN_HOSTWHITELIST_HOSTS=[]
SILLYTAVERN_HOSTWHITELIST_ENABLED=false

# =============================================================================
# SillyTavern: User Authentication
# =============================================================================

# Basic Authentication
SILLYTAVERN_BASICAUTHMODE=false
SILLYTAVERN_SESSIONTIMEOUT=-1
SILLYTAVERN_PERUSERBASICAUTH=false
SILLYTAVERN_ENABLEUSERACCOUNTS=true
SILLYTAVERN_ENABLEDISCREETLOGIN=true
# CHANGE THESE BEFORE ENABLING BASIC AUTH
SILLYTAVERN_BASICAUTHUSER_USERNAME=user
SILLYTAVERN_BASICAUTHUSER_PASSWORD=password

# SSO Auto-Login
SILLYTAVERN_SSO_AUTHELIAAUTH=false
SILLYTAVERN_SSO_AUTHENTIKAUTH=false

# =============================================================================
# SillyTavern: Rate Limiting Configuration
# =============================================================================

SILLYTAVERN_RATELIMITING_PREFERREALIPHEADER=true

# =============================================================================
# SillyTavern: Request Proxy Configuration
# =============================================================================

SILLYTAVERN_REQUESTPROXY_ENABLED=false
SILLYTAVERN_REQUESTPROXY_URL=socks5://username:password@example.com:1080
# JSON array format: ["localhost", "127.0.0.1"]
SILLYTAVERN_REQUESTPROXY_BYPASS=["localhost", "127.0.0.1"]

# =============================================================================
# SillyTavern: CORS Proxy Configuration
# =============================================================================

SILLYTAVERN_ENABLECORSPROXY=false

# =============================================================================
# SillyTavern: Browser Launch Configuration
# =============================================================================

SILLYTAVERN_BROWSERLAUNCH_ENABLED=false
SILLYTAVERN_BROWSERLAUNCH_BROWSER=default
SILLYTAVERN_BROWSERLAUNCH_HOSTNAME=auto
SILLYTAVERN_BROWSERLAUNCH_PORT=-1
SILLYTAVERN_BROWSERLAUNCH_AVOIDLOCALHOST=false

# =============================================================================
# SillyTavern: Performance Configuration
# =============================================================================

SILLYTAVERN_PERFORMANCE_LAZYLOADCHARACTERS=true
SILLYTAVERN_PERFORMANCE_USEDISKCACHE=true
SILLYTAVERN_PERFORMANCE_MEMORYCACHECAPACITY=100mb

# =============================================================================
# SillyTavern: Cache Buster Configuration
# =============================================================================

SILLYTAVERN_CACHEBUSTER_ENABLED=true
SILLYTAVERN_CACHEBUSTER_USERAGENTPATTERN=

# =============================================================================
# SillyTavern: Thumbnailing Configuration
# =============================================================================

SILLYTAVERN_THUMBNAILS_ENABLED=true
SILLYTAVERN_THUMBNAILS_QUALITY=95
SILLYTAVERN_THUMBNAILS_FORMAT=jpg
# JSON array format: [160, 90]
SILLYTAVERN_THUMBNAILS_DIMENSIONS_BG=[160, 90]
# JSON array format: [96, 144]
SILLYTAVERN_THUMBNAILS_DIMENSIONS_AVATAR=[96, 144]
# JSON array format: [96, 144]
SILLYTAVERN_THUMBNAILS_DIMENSIONS_PERSONA=[96, 144]

# =============================================================================
# SillyTavern: Backup Configuration
# =============================================================================

SILLYTAVERN_BACKUPS_CHAT_ENABLED=true
SILLYTAVERN_BACKUPS_CHAT_CHECKINTEGRITY=true
SILLYTAVERN_BACKUPS_COMMON_NUMBEROFBACKUPS=50
SILLYTAVERN_BACKUPS_CHAT_THROTTLEINTERVAL=10000
SILLYTAVERN_BACKUPS_CHAT_MAXTOTALBACKUPS=-1

# =============================================================================
# SillyTavern: Extensions Configuration
# =============================================================================

SILLYTAVERN_EXTENSIONS_ENABLED=true
SILLYTAVERN_EXTENSIONS_AUTOUPDATE=true
SILLYTAVERN_EXTENSIONS_MODELS_AUTODOWNLOAD=true
SILLYTAVERN_EXTENSIONS_MODELS_CLASSIFICATION=Cohee/distilbert-base-uncased-go-emotions-onnx
SILLYTAVERN_EXTENSIONS_MODELS_CAPTIONING=Xenova/vit-gpt2-image-captioning
SILLYTAVERN_EXTENSIONS_MODELS_EMBEDDING=Cohee/jina-embeddings-v2-base-en
SILLYTAVERN_EXTENSIONS_MODELS_SPEECHTOTEXT=Xenova/whisper-small
SILLYTAVERN_EXTENSIONS_MODELS_TEXTTOSPEECH=Xenova/speecht5_tts

# =============================================================================
# SillyTavern: Server Plugins
# =============================================================================

SILLYTAVERN_ENABLESERVERPLUGINS=false
SILLYTAVERN_ENABLESERVERPLUGINSAUTOUPDATE=true

# =============================================================================
# SillyTavern: API Integration Settings
# =============================================================================

SILLYTAVERN_PROMPTPLACEHOLDER=[Start a new chat]

# =============================================================================
# SillyTavern: OpenAI Configuration
# =============================================================================

SILLYTAVERN_OPENAI_RANDOMIZEUSERID=false
SILLYTAVERN_OPENAI_CAPTIONSYSTEMPROMPT=

# =============================================================================
# SillyTavern: MistralAI Configuration
# =============================================================================

SILLYTAVERN_MISTRAL_ENABLEPREFIX=false

# =============================================================================
# SillyTavern: Ollama Configuration
# =============================================================================

SILLYTAVERN_OLLAMA_KEEPALIVE=-1
SILLYTAVERN_OLLAMA_BATCHSIZE=-1

# =============================================================================
# SillyTavern: Claude Configuration
# =============================================================================

SILLYTAVERN_CLAUDE_ENABLESYSTEMPROMPTCACHE=false
SILLYTAVERN_CLAUDE_CACHINGATDEPTH=-1
SILLYTAVERN_CLAUDE_EXTENDEDTTL=false

# =============================================================================
# SillyTavern: Google Gemini Configuration
# =============================================================================

SILLYTAVERN_GEMINI_APIVERSION=v1beta
SILLYTAVERN_GEMINI_ENABLESYSTEMPROMPTCACHE=false
SILLYTAVERN_GEMINI_IMAGE_PERSONGENERATION=allow_adult

# =============================================================================
# SillyTavern: DeepL Configuration
# =============================================================================

SILLYTAVERN_DEEPL_FORMALITY=default

# =============================================================================
# Healthcheck Configuration
# =============================================================================

SILLYTAVERN_HEALTHCHECK_RETRIES=5
SILLYTAVERN_HEALTHCHECK_TIMEOUT=5s
SILLYTAVERN_HEALTHCHECK_INTERVAL=10s
SILLYTAVERN_HEALTHCHECK_START_PERIOD=15s

# =============================================================================
# Logging Configuration
# =============================================================================

SILLYTAVERN_LOG_MAX_FILE=3
SILLYTAVERN_LOG_MAX_SIZE=10m

# =============================================================================
# Volume Names
# =============================================================================

SILLYTAVERN_CONFIG_VOLUME_NAME=sillytavern-config
SILLYTAVERN_DATA_VOLUME_NAME=sillytavern-data
SILLYTAVERN_PLUGINS_VOLUME_NAME=sillytavern-plugins
SILLYTAVERN_EXTENSIONS_VOLUME_NAME=sillytavern-extensions

# =============================================================================
# Network Configuration
# =============================================================================

SERVICES_NETWORK_NAME=services
