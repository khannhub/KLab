# LobeChat Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Images / tags
# =============================================================================

LOBECHAT_IMAGE=lobehub/lobe-chat-database
LOBECHAT_TAG=latest

LOBECHAT_POSTGRES_IMAGE=pgvector/pgvector
LOBECHAT_POSTGRES_TAG=pg16

# =============================================================================
# Service ports / general config
# =============================================================================

LOBECHAT_PORT=3210

# =============================================================================
# REQUIRED core env (server database mode)
# =============================================================================

# Public/base URL of the deployed site.
APP_URL=https://lobechat.example.com

# Required: encryption key for sensitive data stored in Postgres.
# Generate: openssl rand -base64 32
KEY_VAULTS_SECRET=replace-me

# Required: NextAuth secret.
# Generate: openssl rand -base64 32
NEXT_AUTH_SECRET=replace-me

# Required: NextAuth callback URL (should be APP_URL + /api/auth in most cases)
NEXTAUTH_URL=https://lobechat.example.com/api/auth

# Optional: comma-separated providers; Authentik is recommended for Docker.
NEXT_AUTH_SSO_PROVIDERS=authentik

# =============================================================================
# Authentik (NextAuth provider)
# =============================================================================
#
# Docs: https://lobehub.com/docs/self-hosting/advanced/auth/next-auth/authentik
#
# Required if NEXT_AUTH_SSO_PROVIDERS includes "authentik".

AUTH_AUTHENTIK_ID=replace-me
AUTH_AUTHENTIK_SECRET=replace-me
AUTH_AUTHENTIK_ISSUER=https://authentik.example.com/application/o/lobechat/

# =============================================================================
# Postgres (pgvector) configuration
# =============================================================================

LOBECHAT_POSTGRES_DB=postgres
LOBECHAT_POSTGRES_USER=postgres
LOBECHAT_POSTGRES_PASSWORD=replace-me
LOBECHAT_POSTGRES_PORT=5432

# =============================================================================
# S3-compatible object storage (recommended)
# =============================================================================
#
# Docs:
# - Overview: https://lobehub.com/docs/self-hosting/server-database
# - S3: https://lobehub.com/docs/self-hosting/advanced/s3
#
# These are required for file upload features; leave blank if you are not using them yet.

S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_BUCKET=
S3_PUBLIC_DOMAIN=

# =============================================================================
# Container lifecycle / identity
# =============================================================================

LOBECHAT_RESTART=always
LOBECHAT_HOSTNAME=lobechat
LOBECHAT_CONTAINER_NAME=lobechat

LOBECHAT_POSTGRES_RESTART=always
LOBECHAT_POSTGRES_HOSTNAME=lobechat-postgres
LOBECHAT_POSTGRES_CONTAINER_NAME=lobechat-postgres

# =============================================================================
# Healthchecks / logging
# =============================================================================

LOBECHAT_HEALTHCHECK_RETRIES=5
LOBECHAT_HEALTHCHECK_TIMEOUT=5s
LOBECHAT_HEALTHCHECK_INTERVAL=10s
LOBECHAT_HEALTHCHECK_START_PERIOD=30s

LOBECHAT_POSTGRES_HEALTHCHECK_RETRIES=5
LOBECHAT_POSTGRES_HEALTHCHECK_TIMEOUT=5s
LOBECHAT_POSTGRES_HEALTHCHECK_INTERVAL=10s
LOBECHAT_POSTGRES_HEALTHCHECK_START_PERIOD=15s

LOBECHAT_LOG_MAX_FILE=3
LOBECHAT_LOG_MAX_SIZE=10m

LOBECHAT_POSTGRES_LOG_MAX_FILE=3
LOBECHAT_POSTGRES_LOG_MAX_SIZE=10m

# =============================================================================
# Persistence
# =============================================================================

LOBECHAT_POSTGRES_VOLUME_NAME=lobechat-postgres-data

# =============================================================================
# Networks
# =============================================================================

# Shared upstream network (external; must be created once)
SERVICES_NETWORK_NAME=services

# Internal network for this stack (created by this compose)
LOBECHAT_NETWORK_NAME=lobechat
LOBECHAT_NETWORK_SUBNET=172.102.0.0/24
LOBECHAT_NETWORK_GATEWAY=172.102.0.1
