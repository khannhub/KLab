# MongoDB Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Images / tags
# =============================================================================

MONGODB_IMAGE=mongo
MONGODB_TAG=7.0

# =============================================================================
# Core database configuration (REQUIRED)
# =============================================================================

MONGODB_ROOT_USERNAME=root
MONGODB_ROOT_PASSWORD=replace-me
MONGODB_DATABASE=app

# =============================================================================
# Timezone / general config
# =============================================================================

MONGODB_TIMEZONE=Etc/UTC

# =============================================================================
# Container lifecycle / identity
# =============================================================================

MONGODB_RESTART=always
MONGODB_HOSTNAME=mongodb
MONGODB_CONTAINER_NAME=mongodb

# =============================================================================
# Healthchecks / logging
# =============================================================================

MONGODB_HEALTHCHECK_RETRIES=5
MONGODB_HEALTHCHECK_TIMEOUT=5s
MONGODB_HEALTHCHECK_INTERVAL=10s
MONGODB_HEALTHCHECK_START_PERIOD=20s

MONGODB_LOG_MAX_FILE=3
MONGODB_LOG_MAX_SIZE=10m

# =============================================================================
# Persistence
# =============================================================================

MONGODB_DATA_VOLUME_NAME=mongodb-data

# =============================================================================
# Networks
# =============================================================================

# Shared upstream network (external; must be created once)
SERVICES_NETWORK_NAME=services
