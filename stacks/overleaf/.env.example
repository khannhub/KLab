# Overleaf Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Container images
# =============================================================================

# Overleaf Community Edition image
OVERLEAF_IMAGE=sharelatex/sharelatex
OVERLEAF_TAG=6.1.1

# MongoDB image (single-node replica set)
OVERLEAF_MONGO_IMAGE=mongo
OVERLEAF_MONGO_TAG=6.0

# Redis image
OVERLEAF_REDIS_IMAGE=redis
OVERLEAF_REDIS_TAG=6.2

# =============================================================================
# Container lifecycle / identity
# =============================================================================

OVERLEAF_PLATFORM=linux/amd64
OVERLEAF_RESTART=unless-stopped
OVERLEAF_HOSTNAME=overleaf
OVERLEAF_CONTAINER_NAME=overleaf

OVERLEAF_MONGO_RESTART=always
OVERLEAF_MONGO_HOSTNAME=overleaf-mongo
OVERLEAF_MONGO_CONTAINER_NAME=overleaf-mongo

OVERLEAF_REDIS_RESTART=always
OVERLEAF_REDIS_HOSTNAME=overleaf-redis
OVERLEAF_REDIS_CONTAINER_NAME=overleaf-redis

OVERLEAF_MONGO_INIT_HOSTNAME=overleaf-mongo-init
OVERLEAF_MONGO_INIT_CONTAINER_NAME=overleaf-mongo-init

# =============================================================================
# Overleaf app configuration
# =============================================================================

# Container timezone
OVERLEAF_TIMEZONE=Etc/UTC

# Overleaf listens on port 80 inside the container (do not change).
OVERLEAF_HTTP_PORT=80

# IMPORTANT: Set to the URL you will actually use (reverse proxy URL).
OVERLEAF_SITE_URL=https://overleaf.example.com

# Display name shown in the UI.
OVERLEAF_APP_NAME=Overleaf Community Edition

# Overleaf <-> Mongo connection. Update if you change Mongo vars below.
OVERLEAF_MONGO_URL=mongodb://overleaf-mongo:27017/sharelatex?replicaSet=overleaf

# Overleaf <-> Redis connection.
OVERLEAF_REDIS_HOST=overleaf-redis

# Disable email confirmation for home setups (set to false to enable).
OVERLEAF_EMAIL_CONFIRMATION_DISABLED=true

# Optional quality-of-life features.
OVERLEAF_ENABLE_CONVERSIONS=true
OVERLEAF_ENABLED_LINKED_FILE_TYPES=project_file,project_output_file

# =============================================================================
# Reverse proxy / TLS (set when running behind HTTPS)
# =============================================================================

OVERLEAF_BEHIND_PROXY=false
OVERLEAF_SECURE_COOKIE=false

# Example: 172.10.0.0/24 or 192.168.1.10
OVERLEAF_TRUSTED_PROXY_IPS=

# =============================================================================
# Mongo configuration (replica set)
# =============================================================================

OVERLEAF_MONGO_DB=sharelatex
OVERLEAF_MONGO_PORT=27017
OVERLEAF_MONGO_REPLICA_SET=overleaf

# =============================================================================
# Redis configuration
# =============================================================================

# Persist snapshots every 60s if at least 1 key changed.
OVERLEAF_REDIS_SAVE_SECONDS=60
OVERLEAF_REDIS_SAVE_CHANGES=1
OVERLEAF_REDIS_LOGLEVEL=warning

# =============================================================================
# Healthcheck / logging
# =============================================================================

# Overleaf app healthcheck
OVERLEAF_HEALTHCHECK_RETRIES=5
OVERLEAF_HEALTHCHECK_TIMEOUT=5s
OVERLEAF_HEALTHCHECK_INTERVAL=10s
OVERLEAF_HEALTHCHECK_START_PERIOD=30s

# Mongo healthcheck
OVERLEAF_MONGO_HEALTHCHECK_RETRIES=5
OVERLEAF_MONGO_HEALTHCHECK_TIMEOUT=5s
OVERLEAF_MONGO_HEALTHCHECK_INTERVAL=10s
OVERLEAF_MONGO_HEALTHCHECK_START_PERIOD=15s

# Redis healthcheck
OVERLEAF_REDIS_HEALTHCHECK_RETRIES=5
OVERLEAF_REDIS_HEALTHCHECK_TIMEOUT=5s
OVERLEAF_REDIS_HEALTHCHECK_INTERVAL=10s
OVERLEAF_REDIS_HEALTHCHECK_START_PERIOD=15s

# Log rotation
OVERLEAF_LOG_MAX_FILE=3
OVERLEAF_LOG_MAX_SIZE=10m

OVERLEAF_MONGO_LOG_MAX_FILE=3
OVERLEAF_MONGO_LOG_MAX_SIZE=10m

OVERLEAF_REDIS_LOG_MAX_FILE=3
OVERLEAF_REDIS_LOG_MAX_SIZE=10m

OVERLEAF_MONGO_INIT_LOG_MAX_FILE=1
OVERLEAF_MONGO_INIT_LOG_MAX_SIZE=5m

# =============================================================================
# Persistence
# =============================================================================

OVERLEAF_DATA_VOLUME_NAME=overleaf-data
OVERLEAF_MONGO_VOLUME_NAME=overleaf-mongo
OVERLEAF_REDIS_VOLUME_NAME=overleaf-redis

# =============================================================================
# Networks
# =============================================================================

# Shared upstream network (external; must be created once)
SERVICES_NETWORK_NAME=services

# Internal network for this stack (created by this compose)
OVERLEAF_NETWORK_NAME=overleaf
OVERLEAF_NETWORK_SUBNET=172.110.0.0/24
OVERLEAF_NETWORK_GATEWAY=172.110.0.1
