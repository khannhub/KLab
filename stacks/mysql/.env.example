# MySQL Stack Environment Variables
#
# Copy this file to .env and customize as needed.
# All values shown are defaults from docker-compose.yml.
#
# Security Note: Never commit .env files with real secrets/passwords.

# =============================================================================
# Images / tags
# =============================================================================

MYSQL_IMAGE=mysql
MYSQL_TAG=8.4

# =============================================================================
# Core database configuration (REQUIRED)
# =============================================================================

MYSQL_ROOT_PASSWORD=replace-me

# Optional: create a default database and app user.
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=replace-me

# =============================================================================
# Timezone / general config
# =============================================================================

MYSQL_TIMEZONE=Etc/UTC

# =============================================================================
# Container lifecycle / identity
# =============================================================================

MYSQL_RESTART=always
MYSQL_HOSTNAME=mysql
MYSQL_CONTAINER_NAME=mysql

# =============================================================================
# Healthchecks / logging
# =============================================================================

MYSQL_HEALTHCHECK_RETRIES=5
MYSQL_HEALTHCHECK_TIMEOUT=5s
MYSQL_HEALTHCHECK_INTERVAL=10s
MYSQL_HEALTHCHECK_START_PERIOD=20s

MYSQL_LOG_MAX_FILE=3
MYSQL_LOG_MAX_SIZE=10m

# =============================================================================
# Persistence
# =============================================================================

MYSQL_DATA_VOLUME_NAME=mysql-data

# =============================================================================
# Networks
# =============================================================================

# Shared upstream network (external; must be created once)
SERVICES_NETWORK_NAME=services
